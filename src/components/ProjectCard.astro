---
interface Props {
  name: string;
  description: string | null;
  language: string | null;
  stars: number;
  url: string;
  pinned: boolean;
}

const { name, description, language, stars, url, pinned } = Astro.props;
---

<a
  class:list={['project-card', { 'project-card--pinned': pinned }]}
  href={url}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="project-card__name">{name}</span>
  {description && <span class="project-card__desc">{description}</span>}
  <span class="project-card__meta">
    {language && <span class="project-card__lang">{language}</span>}
    {stars > 0 && <span class="project-card__stars">{stars}</span>}
  </span>
</a>
